# Default: SQLite for easy local development
# To use PostgreSQL instead, change DATABASE_URL to:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/second_serving
DATABASE_URL=sqlite+aiosqlite:///./second_serving.db

SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=your-openai-api-key-here
